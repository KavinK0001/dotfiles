[global]
    ### Display ###
    monitor = 0
    follow = none

    ### Geometry ###
    width = 350
    height = (0, 150)
    origin = top-right
    offset = 16x50
    scale = 0
    notification_limit = 5
    gap_size = 8

    ### Progress bar ###
    progress_bar = true
    progress_bar_height = 6
    progress_bar_frame_width = 0
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 3

    ### Appearance ###
    transparency = 0
    padding = 14
    horizontal_padding = 16
    text_icon_padding = 12
    frame_width = 2
    frame_color = "#7aa2f7"
    gap_size = 8
    corner_radius = 10
    icon_corner_radius = 6

    ### Icons ###
    icon_position = left
    min_icon_size = 48
    max_icon_size = 64
    icon_theme = "Papirus-Dark, hicolor"
    enable_recursive_icon_lookup = true

    ### Text ###
    font = JetBrainsMono Nerd Font 11
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    ### Misc ###
    dmenu = /usr/bin/rofi -dmenu -p dunst
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 10
    ignore_dbusclose = false
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = false

[urgency_low]
    background = "#1a1b26"
    foreground = "#a9b1d6"
    frame_color = "#3b4261"
    highlight = "#7dcfff"
    timeout = 4
    #icon = /path/to/icon

[urgency_normal]
    background = "#1a1b26"
    foreground = "#c0caf5"
    frame_color = "#7aa2f7"
    highlight = "#7aa2f7"
    timeout = 6

[urgency_critical]
    background = "#1a1b26"
    foreground = "#f7768e"
    frame_color = "#f7768e"
    highlight = "#f7768e"
    timeout = 0
```

**Color breakdown (Tokyo Night):**
- Background: `#1a1b26` — the classic TN dark base
- Normal text: `#c0caf5` — soft lavender white
- Border (normal): `#7aa2f7` — TN blue
- Low urgency border: `#3b4261` — subtle, dim
- Critical: `#f7768e` — TN red/pink
- Highlight: follows urgency color (used for progress bar)

**For Hyprland blur**, add to `hyprland.conf`:
```
layerrule = blur, dunst
layerrule = ignorezero, dunst1
